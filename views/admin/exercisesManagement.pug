extends ../base

block styles
  link(rel="stylesheet" href="/css/exerciseManagement.css")

block content

  // =========================
  // BACK BUTTON
  // =========================
  a.back-btn(href='/adminDashboard') Back

  // =========================
  // USER INFO
  // =========================
  h1.page-title #{title}
  h2 #{user.username}

  if user.pfpUrl
    img.profile-big(src=user.pfpUrl alt="Profile Picture")
  else
    img.profile-big(src="/img/default-user.png" alt="Default Profile")

  // =========================
  // IMPORT EXERCISES
  // =========================
  .import-zone
    h3 📥 Import Exercises (ExerciseDB)
    p
      | This will fetch dumbbell exercises from ExerciseDB API.
      br
      | ⚠️ This process is slow and rate-limited (≈1 minute per muscle group).
    button#importExercisesBtn Import Exercises
    p#importMessage

  // =========================
  // DANGER ZONE
  // =========================
  .danger-zone
    h3 ⚠️ Danger Zone
    p This will permanently delete ALL exercises. This action cannot be undone.
    button#deleteAllExercisesBtn Delete ALL Exercises
    p#deleteMessage

  hr

  // =========================
  // SCROLLABLE EXERCISE LIST
  // =========================
  if exercises.length === 0
    p No exercises available.
  else
    .exercise-list-container
      each exercise in exercises
        .exercise-card
          .exercise-content
            h3 #{exercise.name}
            p
              strong Target:
              |  #{exercise.target}

            if exercise.gifURL
              img.exercise-gif(src=exercise.gifURL alt=exercise.name)

            if exercise.instructions && exercise.instructions.length
              h4 Instructions
              ul
                each step in exercise.instructions
                  li #{step}

block scripts
  script(src="/js/exercisesManagement.js")
