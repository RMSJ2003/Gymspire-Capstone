extends base

block content
  style.
    *,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
    body{font-family:Arial,sans-serif;background-color:#dddddd;padding-top:4rem;color:whitesmoke}
    .edit-profile-page{min-height:100vh;display:flex;justify-content:center;align-items:center;padding:3rem 1rem;flex-direction:column;text-align:center}
    .top-bar{position:fixed;top:0;left:0;right:0;display:flex;justify-content:space-between;padding:.8rem 1rem;z-index:999;background-color:white;backdrop-filter:blur(8px);box-shadow:0 2px 8px rgba(0,0,0,.4)}
    .top-bar a{padding:.5rem 1rem;border:2px solid #d25353;background-color:#d25353;color:whitesmoke;font-weight:bold;border-radius:.5rem;text-decoration:none;transition:all .3s ease}
    .top-bar a:hover{color:#f4c430;border:2px solid transparent}
    .edit-card{background:white;backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);border:1px solid #d25353;border-radius:1rem;padding:2rem;width:100%;max-width:420px;box-shadow:0 8px 32px rgba(0,0,0,.3);display:flex;flex-direction:column;align-items:center;gap:1.2rem}
    .edit-card h1{text-align:center;margin-bottom:1rem;font-size:2rem;font-weight:700;color:black}
    .edit-profile-pic{width:160px;height:160px;border-radius:50%;object-fit:cover;border:4px solid #ebd31b;box-shadow:0 8px 20px rgba(0,0,0,.4);margin-bottom:1.5rem}
    form{display:flex;flex-direction:column;gap:1rem;width:100%}
    label{font-weight:600;font-size:.95rem;margin-bottom:.3rem;display:block;color:#d25353}
    input[type="text"],input[type="file"]{width:100%;padding:.6rem;border-radius:.5rem;border:none;background-color:whitesmoke;color:black;display:block}
    input::placeholder{color:#9ca3af;opacity:1}
    button{margin-top:.5rem;padding:.7rem;border-radius:.6rem;border:none;background:#d25353;color:whitesmoke;font-weight:600;cursor:pointer;width:100%;box-shadow:0 4px 10px rgba(0,0,0,.3);transition:all .3s ease}
    button:hover{color:#f4c430}
    .form-message{text-align:center;font-size:.9rem;min-height:1.2rem;color:#11de0e}
    @media(max-width:900px){.edit-card{padding:1.5rem}.edit-profile-pic{width:140px;height:140px}button{padding:.6rem}input[type="text"],input[type="file"]{padding:.5rem}}

  // 🔹 TOP BAR
  .top-bar
    if user.userType === "user"
      a.dashboard-btn(href='/dashboard') Dashboard
    if user.userType === "coach"
      a.dashboard-btn(href='/coachDashboard') Dashboard
    if user.userType === "admin"
      a.dashboard-btn(href='/adminDashboard') Dashboard
    a.back-btn(href='javascript:history.back()') Back

  .edit-profile-page
    .edit-card
      h1 #{title}

      if currentUser.pfpUrl
        img.edit-profile-pic(src=currentUser.pfpUrl alt="Profile Picture")
      else
        img.edit-profile-pic(src="/img/default-user.png" alt="Default Profile")

      form#editProfileForm(enctype="multipart/form-data")
        p.form-message#formMessage
        label(for="username") Username
        input(
          type="text"
          name="username"
          id="username"
          value=currentUser.username
        )
        label(for="pfp") Profile Picture
        input(type="file" name="pfp" id="pfp" accept="image/*")
        button(type="submit") Save Changes

block scripts
  script(src='/js/editProfile.js')